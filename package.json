{
  "name": "chiken-easy",
  "version": "0.1.0",
  "description": "sing-box multi-node control panel with mTLS agents.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node server/index.js",
    "dev:agent": "node agent/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.js",
    "lint": "node scripts/check.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.7",
    "vite": "^6.0.3",
    "ws": "^8.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {}
}
