# chiken-easy example environment
# Copy this file to .env before using docker compose.

# ===== Server / panel =====
PORT=7788
CHIKEN_BOOTSTRAP_TOKEN=change-me-bootstrap-token
CHIKEN_API_TOKEN=change-me-api-token
CHIKEN_ADMIN_USER=admin
# Strongly recommended. If omitted, the server will generate a random bootstrap password
# on first start and print it to container logs.
CHIKEN_ADMIN_PASSWORD=change-me-admin-password

# ===== Shared agent settings =====
CHIKEN_AGENT_NAME=main
CHIKEN_AGENT_HOST=main
CHIKEN_AGENT_IP=
CHIKEN_SERVICE_MODE=docker
CHIKEN_HOST_PROC=/host/proc
CHIKEN_HOST_ETC=/host/etc
CHIKEN_DISK_PATH=/host/proc/1/root
SINGBOX_CONTAINER=chiken-singbox
SINGBOX_CONFIG=/etc/sing-box/config.json
CHIKEN_FORWARDER_DIR=/app/forwarders

# ===== Remote-agent-only =====
# Example: ws://your-server-ip:7788/agent
CHIKEN_SERVER=ws://127.0.0.1:7788/agent
